FROM ubuntu:22.04

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update && \
    apt-get install -y sudo git curl zlib1g-dev libjpeg-dev libfreetype6-dev libatlas-base-dev libopenblas-dev

RUN useradd -ms /bin/bash klipper && adduser klipper dialout
RUN mkdir /home/klipper/config
VOLUME /home/klipper/config

WORKDIR /home/klipper

USER root

ARG GITHUB_FORK_URL=https://github.com/0xD34D/klipper_ender3_v3_se.git
RUN git clone --depth=1 $GITHUB_FORK_URL /home/klipper/klipper

RUN echo 'klipper ALL=(ALL:ALL) NOPASSWD: ALL' > /etc/sudoers.d/klipper && \
    chown klipper:klipper -R /home/klipper && \
    ln -s /bin/true /bin/systemctl

USER klipper

RUN /home/klipper/klipper/scripts/install-ubuntu-22.04.sh

RUN git clone https://github.com/Frix-x/klippain-shaketune.git
RUN /home/klipper/klippy-env/bin/pip install -r klippain-shaketune/requirements.txt
RUN mkdir -p /home/klipper/klipper/klippy/extras/shaketune
RUN cp -r klippain-shaketune/shaketune /home/klipper/klipper/klippy/extras/

USER root
RUN rm -f /bin/systemctl

USER klipper

RUN mkdir -p /home/klipper/printer_data && chown klipper:klipper /home/klipper/printer_data

CMD ["/home/klipper/klippy-env/bin/python", "/home/klipper/klipper/klippy/klippy.py", "/home/klipper/config/printer.cfg", "-a", "/home/klipper/klipper_uds"]
